# Grok signup config — copy to .env and fill in your own values
#
# docker compose up -d

# 9router
ROUTER9_URL=https://your-9router.example
ROUTER9_PASS=your_9router_password

# Gmail IMAP reading for verification codes
# Use app password, NOT your regular Gmail password. Enable IMAP in Gmail settings.
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_DOMAINS=youraliasdomain.com,example.com

# Password for the Grok accounts being created (≥16 chars)
PASSWORD=ChangeMe12345678!

# Docker / runner tuning
MAX_ACCOUNTS=0          # <=0 = infinite (bulk-cf style)
BATCH_SIZE=1
PAUSE_SECONDS=10
DELAY_SECONDS=5
MAX_ACCOUNT_RETRIES=3
AUTO_ADD=true

# Optional: external Turnstile solver (NextCaptcha / Anti-Captcha style createTask API)
# CAPTCHA_API_KEY=your_api_key
# CAPTCHA_PROVIDER=nextcaptcha
# CAPTCHA_API_URL=https://api.nextcaptcha.com/v2

